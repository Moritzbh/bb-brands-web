{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": true,
  "rewrites": [
    { "source": "/api/:path*/", "destination": "/api/:path*" }
  ],
  "redirects": [
    {
      "source": "/founder-os",
      "destination": "https://founder-os.bb-brands.de",
      "permanent": true
    },
    {
      "source": "/founder-os/",
      "destination": "https://founder-os.bb-brands.de",
      "permanent": true
    },
    {
      "source": "/founder-os/:path+",
      "destination": "https://founder-os.bb-brands.de/:path+",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/assets/(.*\\.(?:css|js))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*\\.(?:png|jpg|jpeg|webp|svg|gif|ico|woff|woff2|ttf|otf|mp4|webm))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.html)?",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate, no-cache" }
      ]
    }
  ]
}
